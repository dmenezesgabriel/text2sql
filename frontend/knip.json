{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/shared/api/generated/**"],
  "ignoreBinaries": ["dot"],
  "ignoreUnresolved": [
    "^html:reports/cucumber-report\\.html$",
    "^progress-bar$",
    "^e2e/step-definitions/"
  ],
  "tags": ["-public"],
  "ignoreDependencies": ["@storybook/blocks", "@storybook/test", "husky", "fallow"],
  "vitest": {
    "config": "vite.config.ts"
  },
  "playwright": {
    "config": "playwright.config.ts"
  },
  "storybook": {
    "config": [".storybook/main.ts"]
  }
}
