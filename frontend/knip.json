  "entry": ["src/main.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts"],
  "ignoreDependencies": [
    "@storybook/blocks",
    "@storybook/test",
    "@storybook/experimental-addon-test",
    "@testing-library/react",
    "@testing-library/user-event",
    "husky",
    "lint-staged"
  ],
  "vitest": {
    "config": "vite.config.ts"
  },
  "playwright": {
    "config": "playwright.config.ts"
  },
  "storybook": {
    "config": [".storybook/main.ts"]
  }
}
