{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "stylelint": "stylelint 'src/**/*.css'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:browser": "vitest run --browser.enabled --browser.name=chromium",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:bdd": "cucumber-js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "knip": "knip",
    "gen:component": "plop component",
    "gen:api": "orval",
    "depcruise": "depcruise src/",
    "depcruise:graph": "depcruise src/ --include-only '^src' --output-type dot | dot -T svg > dependency-graph.svg",
    "jscpd": "jscpd .",
    "mutate": "stryker run",
    "postinstall": "echo 'Hooks managed by root husky — see .husky/ at repo root'"
  },
  "dependencies": {
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@lit/react": "1.0.8",
    "chart.js": "4.5.1",
    "lit": "3.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0",
    "zod": "3.25.76",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@cucumber/cucumber": "13.0.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.4",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/blocks": "8.6.14",
    "@storybook/experimental-addon-test": "8.6.14",
    "@storybook/test": "8.6.15",
    "@storybook/web-components-vite": "10.4.4",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "dependency-cruiser": "17.4.3",
    "eslint": "10.4.1",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-lit": "2.3.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "65.0.1",
    "fallow": "2.95.0",
    "husky": "9.1.7",
    "jscpd": "5.0.8",
    "jsdom": "29.1.1",
    "knip": "6.16.1",
    "lint-staged": "17.0.7",
    "msw": "2.14.6",
    "msw-storybook-addon": "2.0.7",
    "orval": "8.17.0",
    "playwright": "1.60.0",
    "plop": "4.0.5",
    "prettier": "3.8.4",
    "storybook": "10.4.4",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "6.4.3",
    "vitest": "4.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  }
}
