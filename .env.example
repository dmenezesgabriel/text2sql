# DynamoDB Local (host port mapped to 8090 to avoid conflict with backend on 8000)
DYNAMODB_HOST=http://localhost:8090
AWS_ACCESS_KEY_ID=fake
AWS_SECRET_ACCESS_KEY=fake
AWS_DEFAULT_REGION=us-east-1

# DuckDB
DUCKDB_PATH=:memory:

# LLM
LLM_MODEL=gpt-4o
SUMMARIZER_MODEL=gpt-4o-mini
TOKEN_LIMIT=100000

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=bi-data

# Provider credentials, read from the environment by the litellm provider.
# Copy to `.env` and fill in only the keys you need; `.env` is gitignored.
# Full provider list: https://docs.litellm.ai/docs/providers
GEMINI_API_KEY=
OPENROUTER_API_KEY=
