# DynamoDB Local (host port mapped to 8090 to avoid conflict with backend on 8000)
DYNAMODB_HOST=http://localhost:8090
AWS_ACCESS_KEY_ID=fake
AWS_SECRET_ACCESS_KEY=fake
AWS_DEFAULT_REGION=us-east-1

# DuckDB
DUCKDB_PATH=:memory:

# LLM — GitHub Copilot via LiteLLM
# Auth: device-flow OAuth; LiteLLM prompts on first call and caches the token
# at GITHUB_COPILOT_TOKEN_DIR (default ~/.config/litellm/github_copilot).
# Confirmed Copilot model names: github_copilot/gpt-4, github_copilot/gpt-5.1-codex
# github_copilot/gpt-4o-mini may work depending on your Copilot subscription.
LLM_MODEL=github_copilot/gpt-4o-mini
SUMMARIZER_MODEL=github_copilot/gpt-4o-mini
TOKEN_LIMIT=100000

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=bi-data

# Provider credentials — only needed if you switch away from GitHub Copilot.
# Copy to `.env` and fill in keys for your chosen provider; `.env` is gitignored.
# Full provider list: https://docs.litellm.ai/docs/providers
GEMINI_API_KEY=
